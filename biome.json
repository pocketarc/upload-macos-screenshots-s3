{
    "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": ["**"]
    },
    "formatter": {
        "enabled": true,
        "useEditorconfig": true,
        "formatWithErrors": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 120
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "domains": {
            "project": "all",
            "types": "all"
        },
        "rules": {
            "complexity": {
                "noExcessiveCognitiveComplexity": {
                    "level": "error",
                    "options": { "maxAllowedComplexity": 15 }
                },
                "useLiteralKeys": {
                    "level": "off"
                }
            },
            "suspicious": {
                "noConsole": {
                    "level": "error",
                    "options": { "allow": ["log", "info", "warn", "error"] }
                },
                "noAlert": "error"
            },
            "correctness": {
                "noUndeclaredVariables": "off",
                "noUnresolvedImports": "off"
            },
            "style": {
                "noProcessEnv": "error",
                "noDefaultExport": "error",
                "noUnusedTemplateLiteral": {
                    "level": "error",
                    "fix": "safe"
                },
                "useNamingConvention": {
                    "level": "warn",
                    "options": {
                        "strictCase": false,
                        "conventions": [
                            {
                                "selector": { "kind": "typeProperty" },
                                "formats": ["snake_case", "camelCase"]
                            },
                            {
                                "selector": { "kind": "objectLiteralProperty" },
                                "formats": ["snake_case", "camelCase", "CONSTANT_CASE"]
                            },
                            {
                                "selector": { "kind": "classProperty" },
                                "formats": ["snake_case", "camelCase"]
                            },
                            {
                                "selector": { "kind": "classGetter" },
                                "formats": ["snake_case", "camelCase"]
                            }
                        ]
                    }
                }
            },
            "nursery": {
                "useExplicitType": "error"
            }
        }
    },
    "javascript": {
        "globals": ["Bun"],
        "formatter": {
            "quoteProperties": "preserve"
        }
    }
}
