{
    "name": "upload-macos-screenshots-s3",
    "version": "2.0.0",
    "type": "module",
    "scripts": {
        "dev": "bun run src/index.ts",
        "build": "bun build src/index.ts --compile --minify --bytecode --target bun --outfile screenshot-uploader --external sharp",
        "lint": "biome check --write src/ && tsc --noEmit && eslint src/"
    },
    "dependencies": {
        "any-ascii": "^0.3.3",
        "ini": "^6.0.0",
        "sharp": "^0.34.5",
        "zod": "^4.3.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.7",
        "@types/bun": "^1.3.5",
        "@types/ini": "^4.1.1",
        "eslint": "^10.4.0",
        "eslint-plugin-security": "^4.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4"
    }
}
