# Each destination is independently switchable (true/false). At least one must be true.
# A flag left unset = false; do not set it to an empty string.
S3_ENABLED=false
SFTP_ENABLED=false
LOCAL_ENABLED=false

# S3 - required only when S3_ENABLED=true. Credentials optional if ~/.aws/credentials exists.
S3_BUCKET=example.com
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
BASE_URL=https://example.com/

# SFTP backup - required only when SFTP_ENABLED=true.
SFTP_HOST=backup.example.com
SFTP_USER=
SFTP_KEY_PATH=~/.ssh/id_ed25519
SFTP_PATH=/backups/screenshots

# Local archive - optional when LOCAL_ENABLED=true (defaults to ~/Pictures/Screenshots).
# LOCAL_PATH=~/Pictures/Screenshots
